SQL> -- WAQTD TOTAL NO OF EMPLOYEES WORKING IN EACH DEPARTMENT IF EACH DEPARTMENT CONSIST OF MORE THAN ONE EMPLOYEE .
SQL> SELECT COUNT(*)
  2  FROM EMP
  3  GROUP BY DEPTNO
  4  HAVING COUNT(*) >1;

  COUNT(*)                                                                      
----------                                                                      
         6                                                                      
         5                                                                      
         3                                                                      

SQL> ED
Wrote file afiedt.buf

  1  SELECT COUNT(*) , DEPTNO
  2  FROM EMP
  3  GROUP BY DEPTNO
  4* HAVING COUNT(*) >1
SQL> /

  COUNT(*)     DEPTNO                                                           
---------- ----------                                                           
         6         30                                                           
         5         20                                                           
         3         10                                                           

SQL> ED
Wrote file afiedt.buf

  1  SELECT COUNT(*) , DEPTNO
  2  FROM EMP
  3  GROUP BY DEPTNO
  4* HAVING COUNT(*) >3
SQL> /

  COUNT(*)     DEPTNO                                                           
---------- ----------                                                           
         6         30                                                           
         5         20                                                           

SQL> -- WAQTD MAXIMUM SALARY,MINIMUM SALARY EARN BY EMPLOYEE IN EACH JOB IF TOTAL SALARY IN EACH JIBMUST BE GREATER THAN 3000 .
SQL> SELECT MAX(SAL) , MIN(SAL)
  2  FROM EMP
  3  GROUP BY JOB
  4  HAVING SUM(SAL)>3000 ;

  MAX(SAL)   MIN(SAL)                                                           
---------- ----------                                                           
      1300        800                                                           
      1600       1250                                                           
      5000       5000                                                           
      2975       2450                                                           
      3000       3000                                                           

