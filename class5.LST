SQL> -- WAQTD average salary earn by employee who are working as a Salesman but earning more than 1000
SQL> 
SQL> SELECT AVG(SAL)
  2  FROM EMP
  3  WHERE JOB = 'SALESMAN' AND SAL > 1000 ;

  AVG(SAL)                                                                                                                                                                                              
----------                                                                                                                                                                                              
      1400                                                                                                                                                                                              

